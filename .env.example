# =============================================================================
# TAO / Bittensor Multi-Agent System — Environment Template
# =============================================================================
# INSTRUKTIONEN:
# 1. Kopiere diese Datei zu .env:   cp .env.example .env
# 2. Fuelle die benoetigten Werte aus
# 3. .env NIEMALS in git committen (ist in .gitignore)
# =============================================================================

# =============================================================================
# ABSCHNITT 1: SYSTEM-MODUS
# =============================================================================

# Wallet-Modus: NO_WALLET | WATCH_ONLY | MANUAL_SIGNING
# NO_WALLET     = Keine Wallet-Verbindung (Recherche-Only)
# WATCH_ONLY    = Public Address ueberwachen (Balance anzeigen)
# MANUAL_SIGNING = Transaktionen vorbereiten, extern signieren
WALLET_MODE=NO_WALLET

# Netzwerk-Modus: testnet | mainnet
# FUER ENTWICKLUNG UND TESTS IMMER "testnet" VERWENDEN!
NETWORK_MODE=testnet

# Betriebsmodus: cli | daemon
# cli    = Interaktive Kommandozeile
# daemon = Hintergrunddienst
OPERATION_MODE=cli

# =============================================================================
# ABSCHNITT 2: WALLET (OPTIONAL — NUR PUBLIC DATA)
# =============================================================================
# ACHTUNG: HIER NUR PUBLIC ADDRESSES EINTRAGEN!
# NIEMALS Private Keys oder Seed Phrases!

# Coldkey Public Address (zum Anzeigen der Balance)
# Format: 5xxxx... (SS58 Bittensor Format)
WALLET_COLDKEY_ADDRESS=

# Hotkey Public Address (zum Anzeigen des Stakes)
# Format: 5xxxx... (SS58 Bittensor Format)
WALLET_HOTKEY_ADDRESS=

# Wallet-Name (fuer Anzeigezwecke)
WALLET_NAME=

# =============================================================================
# ABSCHNITT 3: BITTENSOR KONFIGURATION
# =============================================================================

# Bittensor Netzwerk-Chain-Endpoint
# Mainnet: wss://entrypoint-finney.opentensor.ai:443
# Testnet: wss://test.finney.opentensor.ai:443
BT_CHAIN_ENDPOINT=wss://test.finney.opentensor.ai:443

# Standard-Subnet (0 = Root, 1-255 = Spezifisches Subnet)
BT_DEFAULT_SUBNET=0

# Timeout fuer Chain-Queries (Sekunden)
BT_CHAIN_TIMEOUT=30

# Maximaler Batch-Size fuer Chain-Queries
BT_BATCH_SIZE=100

# =============================================================================
# ABSCHNITT 4: DASHBOARD (OPTIONAL)
# =============================================================================

# Streamlit Dashboard aktivieren: true | false
DASHBOARD_ENABLED=false

# Port fuer das Dashboard
DASHBOARD_PORT=8501

# Host fuer das Dashboard (0.0.0.0 fuer externen Zugriff)
DASHBOARD_HOST=127.0.0.1

# Automatischer Browser-Start: true | false
DASHBOARD_AUTO_OPEN=false

# =============================================================================
# ABSCHNITT 5: DATENBANK
# =============================================================================

# Pfad zur SQLite-Datenbank
DATABASE_PATH=data/agents.db

# Backup-Intervall (Sekunden)
DATABASE_BACKUP_INTERVAL=3600

# Backup-Verzeichnis
DATABASE_BACKUP_DIR=data/backups/

# Max. Anzahl Backups (aeltste werden geloescht)
DATABASE_MAX_BACKUPS=10

# =============================================================================
# ABSCHNITT 6: LOGGING
# =============================================================================

# Log-Level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Log-Verzeichnis
LOG_DIR=logs/

# Log-Datei
LOG_FILE=agents.log

# Log-Rotation: true | false
LOG_ROTATION=true

# Max. Log-Datei-Groesse (MB)
LOG_MAX_SIZE=10

# Max. Anzahl Log-Dateien
LOG_MAX_FILES=5

# Strukturiertes Logging (JSON): true | false
LOG_JSON_FORMAT=true

# =============================================================================
# ABSCHNITT 7: RISK & SAFETY
# =============================================================================

# Risk-Score-Schwellenwerte
RISK_SAFE_THRESHOLD=25
RISK_CAUTION_THRESHOLD=50
RISK_DANGER_THRESHOLD=70
RISK_VETO_THRESHOLD=85

# Zeitverzoegerung fuer DANGER-Aktionen (Sekunden)
RISK_DANGER_DELAY=300

# Maximaler TAO-Betrag ohne DANGER-Approval (fuer Transfer/Stake)
RISK_MAX_SAFE_TAO=1.0

# Maximaler TAO-Betrag der ueberhaupt erlaubt ist
RISK_MAX_ABSOLUTE_TAO=100.0

# =============================================================================
# ABSCHNITT 8: DATENQUELLEN
# =============================================================================

# CoinGecko API (Preisdaten)
# Kostenloser API-Key bei coingecko.com
COINGECKO_API_KEY=

# CoinGecko API Endpoint
COINGECKO_API_URL=https://api.coingecko.com/api/v3

# Bittensor Explorer URL
BITTENSOR_EXPLORER_URL=https://taostats.io

# GitHub API Token (optional, erhoeht Rate-Limit)
GITHUB_API_TOKEN=

# Cache-TTL fuer Preisdaten (Sekunden)
CACHE_TTL_PRICE=300

# Cache-TTL fuer Chain-Daten (Sekunden)
CACHE_TTL_CHAIN=60

# Cache-TTL fuer Subnet-Daten (Sekunden)
CACHE_TTL_SUBNET=600

# =============================================================================
# ABSCHNITT 9: AGENT-KONFIGURATION
# =============================================================================

# Default Agent-Timeout (Sekunden)
AGENT_DEFAULT_TIMEOUT=30

# Max. parallele Agenten
AGENT_MAX_PARALLEL=5

# Meta-Agent Review-Intervall (Runs zwischen Reviews)
META_REVIEW_INTERVAL=5

# Code Review Agent aktiviert: true | false
CODE_REVIEW_ENABLED=true

# Data Validation aktiviert: true | false
DATA_VALIDATION_ENABLED=true

# =============================================================================
# ABSCHNITT 10: SICHERHEIT
# =============================================================================

# Strict Mode: true = Alle Sicherheitsregeln strikt durchsetzen
SAFETY_STRICT_MODE=true

# Privaten Modus deaktivieren: true | false
# true = Keine Wallet-Daten in Logs/Reports
PRIVACY_MODE=true

# Audit-Log aktivieren: true | false
AUDIT_LOG_ENABLED=true

# =============================================================================
# ABSCHNITT 11: ENTWICKLUNG
# =============================================================================

# Debug-Modus: true | false
DEBUG=false

# Hot Reload fuer Agenten: true | false
HOT_RELOAD=false

# Profiling aktivieren: true | false
PROFILING_ENABLED=false

# =============================================================================
# ABSCHNITT 12: API-KEYS (OPTIONAL)
# =============================================================================
# Nur fuellen wenn entsprechende Features genutzt werden!

# OpenAI API Key (optional, fuer erweiterte Analysen)
OPENAI_API_KEY=

# Anthropic API Key (optional, fuer erweiterte Analysen)
ANTHROPIC_API_KEY=

# =============================================================================
# WICHTIGE HINWEISE
# =============================================================================
# 1. Diese .env.example DARF in git committet werden.
# 2. Die generierte .env Datei DARF NIEMALS in git landen.
# 3. Private Keys und Seed Phrases haben hier NICHTS verloren.
# 4. Bei Unsicherheit: WALLET_MODE=NO_WALLET verwenden.
# =============================================================================
